{
  "name": "@w8tcha/npm-check",
  "version": "7.0.0",
  "description": "Check for outdated, incorrect, and unused dependencies.",
  "type": "module",
  "main": "./lib/index.js",
  "engines": {
    "node": ">=24.18.0"
  },
  "types": "./index.d.ts",
  "typings": "./index.d.ts",
  "scripts": {
    "lint": "xo",
    "test": "npm run lint && ./bin/cli.js || echo Exit Status: $?."
  },
  "xo": [
    {
      "ignores": [
        "index.d.ts"
      ]
    },
    {
      "space": 4,
      "rules": {
        "no-warning-comments": [
          0
        ]
      }
    }
  ],
  "bin": {
    "npm-check": "bin/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/w8tcha/npm-check.git"
  },
  "keywords": [
    "npm",
    "outdated",
    "dependencies",
    "unused",
    "changelog",
    "check",
    "updates",
    "api",
    "interactive",
    "cli",
    "safe",
    "updating",
    "updater",
    "installer",
    "devDependencies"
  ],
  "author": {
    "name": "Dylan Greene",
    "email": "dylang@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/w8tcha/npm-check/issues"
  },
  "homepage": "https://github.com/w8tcha/npm-check",
  "files": [
    "bin",
    "lib"
  ],
  "dependencies": {
    "callsite-record": "^4.1.5",
    "chalk": "^5.6.2",
    "depcheck": "^1.4.7",
    "execa": "^10.0.0",
    "giturl": "^2.0.0",
    "global-modules": "^2.0.0",
    "globby": "^16.2.2",
    "inquirer": "^14.0.2",
    "is-ci": "^4.1.0",
    "lodash": "^4.18.1",
    "meow": "^14.1.0",
    "minimatch": "^10.2.5",
    "node-emoji": "^2.2.0",
    "ora": "^9.4.1",
    "package-json": "^10.0.1",
    "path-exists": "^5.0.0",
    "pkg-dir": "^9.0.0",
    "preferred-pm": "^5.0.0",
    "rc-config-loader": "^4.1.4",
    "semver": "^7.8.5",
    "semver-diff": "^5.0.0",
    "strip-ansi": "^7.2.0",
    "text-table": "^0.2.0",
    "throat": "^6.0.2",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "xo": "^4.0.0"
  }
}
